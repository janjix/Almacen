// ============================================================
// NLP PARSER — improved with normalization
// ============================================================
const W2N={'un':1,'una':1,'dos':2,'tres':3,'cuatro':4,'cinco':5,'seis':6,'siete':7,'ocho':8,'nueve':9,'diez':10,'once':11,'doce':12,'quince':15,'veinte':20,'treinta':30,'cuarenta':40,'cincuenta':50,'cien':100};
const BRANDS=['masisa','vesto','arauco','egger','kronospan','duratex','faplac','novopan'];
const TKW={tablero:['tablero','tableros','lamina','lámina','laminas','láminas','plancha','planchas'],tapacanto:['tapacanto','tapacantos','tapa canto','canto','cantos','cinta']};
const AKW=['cocina','baño','baños','sala','comedor','habitacion','dormitorio','closet','lavanderia','terraza','balcon','oficina','recepcion','estudio','pasillo','vestidor','despensa','bar','isla','alacena','gabinete','cuarto'];

function pTxt(text){const t=text.toLowerCase().replace(/,/g,' ').replace(/\s+/g,' ').trim();const r={tipo:null,nombre:null,marca:null,espesor:null,cantidad:null,ancho:null,largo:null,altoTC:null,proy:null,area:null,m2:null,partida:null};
// tipo
for(const[tipo,kws]of Object.entries(TKW)){for(const kw of kws)if(t.includes(kw)){r.tipo=tipo;break;}if(r.tipo)break;}
// partida
const ptm=t.match(/(?:partida|código|codigo)\s+([a-z0-9][\w-]*(?:\s+[a-záéíóúñ]+)*)/i);if(ptm){const ptxt=ptm[1].trim();const found=parts.find(p=>norm(p.code+' '+p.name).includes(norm(ptxt))||norm(ptxt).includes(norm(p.code)));if(found)r.partida=found.code+' '+found.name;}
// proyecto
const pp=[/(?:al?\s+)?(?:proyecto|obra)\s+(?:de\s+|del\s+)?(.+?)(?:\s+(?:area|área|zona|partida))/i,/(?:al?\s+)?(?:proyecto|obra)\s+(?:de\s+|del\s+)?([a-záéíóúñ0-9\s]+?)$/i,/(?:al?\s+)?(?:proyecto|obra)\s+(?:de\s+|del\s+)?([a-záéíóúñ0-9\s]+)/i];for(const p of pp){const m=t.match(p);if(m&&m[1]){let v=m[1].trim().replace(/\s+(al?|en|para|de|del|con)$/i,'').trim();if(v.length>0&&v.length<60){// Match against known projects
const known=[...new Set(desp.map(d=>d.proy).filter(Boolean))];const match=known.find(k=>sameish(k,v));r.proy=match||cap(v);break;}}}
// area
const ap=[/(?:area|área|zona)\s+(?:de\s+|del?\s+)?(?:la\s+)?([a-záéíóúñ\s]+?)(?:\s+\d|\s+proyecto|\s*$)/i,/(?:area|área|zona)\s+(?:de\s+|del?\s+)?(?:la\s+)?([a-záéíóúñ\s]+)/i];for(const p of ap){const m=t.match(p);if(m&&m[1]){let v=m[1].trim().replace(/\s+(al?|en|para|proyecto|obra|partida)$/i,'').trim();if(v.length>0&&v.length<40){const known=[...new Set(desp.map(d=>d.area).filter(Boolean))];const match=known.find(k=>sameish(k,v));r.area=match||cap(v);break;}}}
if(!r.area)for(const kw of AKW)if(t.includes(kw)){r.area=cap(kw);break;}
// m2
const mp=t.match(/(\d+(?:[.,]\d+)?)\s*(?:metros?\s*cuadrados?|m2|m²)/i);if(mp)r.m2=parseFloat(mp[1].replace(',','.'));
// espesor
const tp=t.match(/(\d+(?:[.,]\d+)?)\s*(?:mm|milimetros?)/i);if(tp)r.espesor=tp[1].replace(',','.');
// dims
const dm=t.match(/(\d{3,4})\s*[xX×]\s*(\d{3,4})/);if(dm){r.ancho=dm[1];r.largo=dm[2];}
const am=t.match(/(?:alto|altura)\s+(?:de\s+)?(\d+(?:[.,]\d+)?)/i);if(am)r.altoTC=am[1];
// marca
for(const b of BRANDS)if(t.includes(b)){r.marca=cap(b);break;}
// cantidad
const qp=[/(\d+(?:[.,]\d+)?)\s*(?:tableros?|laminas?|láminas?|planchas?|tapacantos?|metros?\s*(?:lineales?)?|mts?|ml)\b/i,/^(\d+(?:[.,]\d+)?)\s/];for(const p of qp){const m=t.match(p);if(m){r.cantidad=parseFloat(m[1].replace(',','.'));break;}}
if(!r.cantidad)for(const[w,n]of Object.entries(W2N))if(new RegExp('\\b'+w+'\\s+(?:tableros?|laminas?|tapacantos?|metros?)\\b','i').test(t)){r.cantidad=n;break;}
// nombre — strip recognized tokens
let ns=t;if(r.proy)ns=ns.replace(/(?:al?\s+)?(?:proyecto|obra)\s+[^\d]*/i,' ');if(r.area){ns=ns.replace(/(?:area|área|zona)\s+[a-záéíóúñ\s]*/i,' ');}if(r.partida)ns=ns.replace(/(?:partida|código|codigo)\s+\S+/i,' ');
ns=ns.replace(/\d+(?:[.,]\d+)?\s*(?:metros?\s*cuadrados?|m2|m²)/gi,' ').replace(/\d+(?:[.,]\d+)?\s*(?:tableros?|laminas?|láminas?|planchas?|tapacantos?|metros?\s*(?:lineales?)?|mts?|ml)\b/gi,' ').replace(/\d+(?:[.,]\d+)?\s*(?:mm|milimetros?)/gi,' ').replace(/\d{3,4}\s*[xX×]\s*\d{3,4}/g,' ');
for(const kws of Object.values(TKW))for(const kw of kws)ns=ns.replace(new RegExp('\\b'+kw.replace(/\s/g,'\\s')+'\\b','gi'),' ');
if(r.marca)ns=ns.replace(new RegExp('\\b'+r.marca.toLowerCase()+'\\b','gi'),' ');
ns=ns.replace(/\b(de|del|la|el|los|las|al|en|para|con|por|un|una|uno|y|que|a|proyecto|obra|area|área|zona|espesor|alto|metros?|cuadrados?|lineales?|marca|partida|código|codigo)\b/gi,' ').replace(/\b\d+(?:[.,]\d+)?\b/g,' ');
for(const w of Object.keys(W2N))ns=ns.replace(new RegExp('\\b'+w+'\\b','gi'),' ');
for(const kw of AKW)ns=ns.replace(new RegExp('\\b'+kw+'\\b','gi'),' ');
ns=ns.replace(/\s+/g,' ').trim();
if(ns.length>0){// Try to match an existing material name
const known=Object.values(inv).map(m=>m.nombre);const match=known.find(k=>sameish(k,ns));r.nombre=match||cap(ns);}
if(!r.tipo)r.tipo='tablero';return r;}
function cap(s){return s.split(' ').map(w=>w.charAt(0).toUpperCase()+w.slice(1).toLowerCase()).join(' ');}

// FUZZY MATCH
function bestMatch(p){const items=Object.values(inv);if(!items.length)return null;let bId=null,bS=0;for(const m of items){let s=0;if(p.tipo&&m.tipo===p.tipo)s+=20;else if(p.tipo&&m.tipo!==p.tipo)s-=50;if(p.nombre&&m.nombre){if(sameish(p.nombre,m.nombre))s+=50;else{const na=normKey(p.nombre),nb=normKey(m.nombre);if(na.includes(nb)||nb.includes(na))s+=35;}}if(p.espesor&&m.espesor&&p.espesor===m.espesor)s+=15;if(p.marca&&m.marca&&sameish(p.marca,m.marca))s+=10;if(s>bS){bS=s;bId=m.id;}}return bS>=25?bId:null;}

