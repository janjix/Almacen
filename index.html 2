function sFlt(f,el){flt=f;document.querySelectorAll('.ft').forEach(t=>t.classList.remove('on'));el.classList.add('on');rInv();}
function rInv(){const s=norm(document.getElementById('srcInv')?.value||''),list=document.getElementById('invList');if(!list)return;const items=Object.values(inv);let tb=items.filter(m=>m.tipo==='tablero'),tc=items.filter(m=>m.tipo==='tapacanto');if(s){const f=m=>norm(m.nombre+' '+m.marca+' '+m.espesor).includes(s);tb=tb.filter(f);tc=tc.filter(f);}if(flt==='tablero')tc=[];if(flt==='tapacanto')tb=[];if(flt==='alertas'){tb=tb.filter(m=>m.cantidad<5);tc=tc.filter(m=>m.cantidad<50);}let h='';if(!tb.length&&!tc.length){h=`<div class="es"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg><p>Sin materiales</p></div>`;list.innerHTML=h;return;}
if(tb.length){h+=`<div class="sh2">Tableros <span class="cnt">${tb.length}</span></div>`;tb.forEach(m=>h+=rMI(m));}
if(tc.length){h+=`<div class="sh2">Tapacantos <span class="cnt">${tc.length}</span></div>`;tc.forEach(m=>h+=rMI(m));}list.innerHTML=h;}
function rMI(m){const isT=m.tipo==='tablero',thr=isT?5:50,lo=m.cantidad<thr,z=m.cantidad<=0,sc=z?'sze':(lo?'slo':'sok'),u=isT?' lám':' mts',sp=isT?`${m.espesor}mm | ${m.ancho}×${m.largo}mm${m.marca?' | '+m.marca:''}`:`${m.espesor}mm${m.altoTC?' | Alto:'+m.altoTC+'mm':''}${m.marca?' | '+m.marca:''}`,lb=lo?`<span class="lsb"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>BAJO</span>`:'';return `<div class="mi ${lo?'low':''}"><div class="mn">${m.nombre} ${lb}</div><div class="ms">${sp}</div><span class="mst ${sc}">${isT?m.cantidad:Number(m.cantidad).toFixed(1)}${u}</span><div class="ma"><button class="ba dsp" onclick="openMD('${m.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>Despachar</button><button class="ba edt" onclick="openEd('${m.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.5 2.5a2.12 2.12 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Editar</button><button class="ba del" onclick="askDel('${m.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>Eliminar</button></div></div>`;}

