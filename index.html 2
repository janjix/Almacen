async function regIng(){const tipo=document.getElementById('inTipo').value,nombre=document.getElementById('inNombre').value.trim(),marca=document.getElementById('inMarca').value.trim(),esp=document.getElementById('inEsp').value.trim();if(!nombre){toast("Falta nombre");return;}if(!esp){toast("Falta espesor");return;}let cant,ancho,largo,alto;if(tipo==='tablero'){cant=parseInt(document.getElementById('inCant').value)||0;ancho=document.getElementById('inAncho').value.trim();largo=document.getElementById('inLargo').value.trim();if(!cant){toast("Falta cantidad");return;}if(!ancho||!largo){toast("Faltan dimensiones");return;}}else{cant=parseFloat(document.getElementById('inMts').value)||0;alto=document.getElementById('inAlto').value.trim();if(!cant){toast("Faltan metros");return;}if(!alto){toast("Falta alto");return;}}
// Find existing with smart matching
let exId=null;for(const id in inv){const m=inv[id];if(m.tipo===tipo&&sameish(m.nombre,nombre)&&sameish(m.marca||'',marca||'')&&m.espesor===esp){if(tipo==='tablero'&&m.ancho===ancho&&m.largo===largo){exId=id;break;}if(tipo==='tapacanto'&&m.altoTC===alto){exId=id;break;}}}
if(exId){inv[exId].cantidad+=(tipo==='tablero'?parseInt(cant):parseFloat(cant));await saveMat(inv[exId]);toast("+"+cant+(tipo==='tapacanto'?' mts':' uds'));}else{const id='m_'+Date.now()+'_'+Math.random().toString(36).substr(2,5);inv[id]={id,tipo,nombre,marca,espesor:esp,ancho:ancho||'',largo:largo||'',altoTC:alto||'',cantidad:tipo==='tablero'?parseInt(cant):parseFloat(cant)};await saveMat(inv[id]);toast("Registrado");}
['inNombre','inMarca','inEsp','inCant','inAncho','inLargo','inAlto','inMts','viI'].forEach(i=>{const e=document.getElementById(i);if(e)e.value='';});document.getElementById('ingPrev').innerHTML='';rInv();rDL();}

