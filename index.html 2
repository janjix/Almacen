<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>
// ============================================================
// SUPABASE
// ============================================================
const SU='TU_SUPABASE_URL',SK='TU_SUPABASE_ANON_KEY';
let sb=null,useSB=false;
try{if(SU!=='TU_SUPABASE_URL'){sb=supabase.createClient(SU,SK);useSB=true;}}catch(e){}

// STATE
let user='',inv={},desp=[],parts=[],flt='todos',selMat=null,parsedMat=null,editId=null;

// ============================================================
// NORMALIZE — core of smart matching
// ============================================================
const STOPWORDS=new Set(['de','del','la','el','los','las','al','en','para','con','por','un','una','uno','y','que','se','me','te','le','a','lo','su','es','mi','tu','nos']);
function norm(s){return(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9\s]/g,'').replace(/\s+/g,' ').trim();}
function normKey(s){return norm(s).split(' ').filter(w=>!STOPWORDS.has(w)&&w.length>1).join(' ');}
function sameish(a,b){if(!a||!b)return false;const na=normKey(a),nb=normKey(b);if(na===nb)return true;if(na.includes(nb)||nb.includes(na))return true;const wa=na.split(' '),wb=nb.split(' ');let m=0;for(const x of wa)for(const y of wb)if(x===y||x.length>3&&y.length>3&&(x.includes(y)||y.includes(x)))m++;return m>=Math.min(wa.length,wb.length)&&m>0;}

// ============================================================
// AUTOCOMPLETE
// ============================================================
function acShow(input,type){
  const v=input.value.trim().toLowerCase();
  const listEl=input.parentElement.querySelector('.ac-list');
  if(v.length<1){listEl.classList.remove('vis');return;}
  let opts=[];
  if(type==='mat')opts=[...new Set(Object.values(inv).map(m=>m.nombre))];
  else if(type==='marca')opts=[...new Set(Object.values(inv).map(m=>m.marca).filter(Boolean))];
  else if(type==='proy')opts=[...new Set(desp.map(d=>d.proyecto).filter(Boolean))];
  else if(type==='area')opts=[...new Set(desp.map(d=>d.area).filter(Boolean))];
  else if(type==='part')opts=parts.map(p=>p.code+' '+p.name);
  const nv=norm(v);
  const filtered=opts.filter(o=>norm(o).includes(nv)).slice(0,6);
  if(!filtered.length){listEl.classList.remove('vis');return;}
  listEl.innerHTML=filtered.map(o=>`<div class="ac-item" onmousedown="acPick(this,'${esc(o)}',event)">${o}</div>`).join('');
  listEl.classList.add('vis');
}
function acPick(el,val,e){e.preventDefault();const input=el.closest('.ac-wrap').querySelector('.fi');input.value=val;el.closest('.ac-list').classList.remove('vis');}
function esc(s){return s.replace(/'/g,"\\'").replace(/"/g,'&quot;');}
document.addEventListener('focusout',e=>{setTimeout(()=>{document.querySelectorAll('.ac-list').forEach(l=>l.classList.remove('vis'));},200);});

// ============================================================
// DATA SYNC
// ============================================================
async function initDB(){
  if(!useSB){loadLoc();return;}
  const{data:m}=await sb.from('materiales').select('*');
  if(m){inv={};m.forEach(r=>{inv[r.id]={id:r.id,tipo:r.tipo,nombre:r.nombre,marca:r.marca||'',espesor:r.espesor,ancho:r.ancho||'',largo:r.largo||'',altoTC:r.alto_tc||'',cantidad:Number(r.cantidad)};});}
  const{data:d}=await sb.from('despachos').select('*').order('timestamp',{ascending:false});
  if(d)desp=d.map(r=>({id:r.id,matId:r.material_id,matName:r.material_name,matSpecs:r.material_specs||'',tipo:r.tipo,cant:Number(r.cantidad),unit:r.unit,m2:Number(r.m2)||0,proy:r.proyecto,area:r.area,partida:r.partida||'',user:r.usuario,ts:Number(r.timestamp)}));
  const{data:p}=await sb.from('partidas').select('*').order('code');
  if(p)parts=p.map(r=>({id:r.id,code:r.code,name:r.name}));
  // Realtime
  sb.channel('all').on('postgres_changes',{event:'*',schema:'public',table:'materiales'},()=>reloadMats()).on('postgres_changes',{event:'*',schema:'public',table:'despachos'},()=>reloadDesp()).on('postgres_changes',{event:'*',schema:'public',table:'partidas'},()=>reloadParts()).subscribe();
}
async function reloadMats(){const{data:m}=await sb.from('materiales').select('*');if(m){inv={};m.forEach(r=>{inv[r.id]={id:r.id,tipo:r.tipo,nombre:r.nombre,marca:r.marca||'',espesor:r.espesor,ancho:r.ancho||'',largo:r.largo||'',altoTC:r.alto_tc||'',cantidad:Number(r.cantidad)};});}rInv();rDL();}
async function reloadDesp(){const{data:d}=await sb.from('despachos').select('*').order('timestamp',{ascending:false});if(d)desp=d.map(r=>({id:r.id,matId:r.material_id,matName:r.material_name,matSpecs:r.material_specs||'',tipo:r.tipo,cant:Number(r.cantidad),unit:r.unit,m2:Number(r.m2)||0,proy:r.proyecto,area:r.area,partida:r.partida||'',user:r.usuario,ts:Number(r.timestamp)}));rRes();rProj();}
async function reloadParts(){const{data:p}=await sb.from('partidas').select('*').order('code');if(p)parts=p.map(r=>({id:r.id,code:r.code,name:r.name}));rParts();}

async function saveMat(m){if(useSB)await sb.from('materiales').upsert({id:m.id,tipo:m.tipo,nombre:m.nombre,marca:m.marca||'',espesor:m.espesor,ancho:m.ancho||'',largo:m.largo||'',alto_tc:m.altoTC||'',cantidad:m.cantidad},{onConflict:'id'});else sLoc();}
async function saveD(d){desp.unshift(d);if(useSB)await sb.from('despachos').insert({id:d.id,material_id:d.matId,material_name:d.matName,material_specs:d.matSpecs,tipo:d.tipo,cantidad:d.cant,unit:d.unit,m2:d.m2||0,proyecto:d.proy,area:d.area,partida:d.partida||'',usuario:d.user,timestamp:d.ts});else sLoc();}
