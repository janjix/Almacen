function parseDesp(){const text=document.getElementById('viD').value.trim();if(!text){toast("Escribí algo");return;}const p=pTxt(text);const mId=bestMatch(p);showDP(p,mId);if(mId){parsedMat=mId;const m=inv[mId],isT=m.tipo==='tablero',u=isT?' lám':' mts',sp=isT?`${m.espesor}mm | ${m.ancho}×${m.largo}mm`:`${m.espesor}mm${m.altoTC?' | Alto:'+m.altoTC+'mm':''}`;document.getElementById('dMatInfo').innerHTML=`<div class="mn">${m.nombre}${m.marca?' — '+m.marca:''}</div><div class="ms">${sp}</div><div class="mst ${m.cantidad<(isT?5:50)?'slo':'sok'}" style="margin-top:5px">Stock: ${isT?m.cantidad:Number(m.cantidad).toFixed(1)}${u}</div>`;document.getElementById('dpM2G').style.display=isT?'block':'none';document.getElementById('dpCant').value=p.cantidad||'';document.getElementById('dpM2').value=p.m2||'';document.getElementById('dpProy').value=p.proy||'';document.getElementById('dpArea').value=p.area||'';document.getElementById('dpPart').value=p.partida||'';document.getElementById('dForm').style.display='block';toast("Encontrado");}else{parsedMat=null;document.getElementById('dForm').style.display='none';toast("No encontrado");}}
function showDP(p,mId){const u=p.tipo==='tapacanto'?' mts':' uds';let h=`<div class="pp"><div class="ppl"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Interpretado</div>`;const R=(k,v,miss)=>`<div class="ppr"><span class="ppk">${k}</span><span class="ppv${miss?' miss':''}">${v||'No detectado'}</span></div>`;h+=R('Tipo',p.tipo==='tablero'?'Tablero':'Tapacanto');h+=R('Nombre',p.nombre,!p.nombre);if(p.espesor)h+=R('Espesor',p.espesor+'mm');h+=R('Cantidad',p.cantidad?p.cantidad+u:null,!p.cantidad);if(p.proy)h+=R('Proyecto',p.proy);if(p.area)h+=R('Área',p.area);if(p.partida)h+=R('Partida',p.partida);if(mId){const m=inv[mId],isT=m.tipo==='tablero',uM=isT?' lám':' mts';h+=`<div class="ppm"><div style="font-size:10px;font-weight:600;color:var(--gn)">✓ ENCONTRADO</div><div style="font-weight:700;font-size:13px">${m.nombre}</div><div style="font-size:11px;color:var(--bkm)">Stock: ${isT?m.cantidad:Number(m.cantidad).toFixed(1)}${uM}</div></div>`;}else h+=`<div class="ppm"><div style="font-size:10px;font-weight:600;color:var(--or)">⚠ NO ENCONTRADO</div></div>`;h+=`</div>`;document.getElementById('dPrev').innerHTML=h;}
async function confDP(){if(!parsedMat)return;const m=inv[parsedMat];if(!m)return;const isT=m.tipo==='tablero',cant=isT?parseInt(document.getElementById('dpCant').value):parseFloat(document.getElementById('dpCant').value),m2=parseFloat(document.getElementById('dpM2').value)||0,proy=document.getElementById('dpProy').value.trim(),area=document.getElementById('dpArea').value.trim(),partida=document.getElementById('dpPart').value.trim();if(!cant||cant<=0){toast("Falta cantidad");return;}if(cant>m.cantidad){toast("Stock insuficiente");return;}if(!proy){toast("Falta proyecto");return;}if(!area){toast("Falta área");return;}await doDsp(parsedMat,cant,m2,proy,area,partida);document.getElementById('viD').value='';document.getElementById('dPrev').innerHTML='';document.getElementById('dForm').style.display='none';parsedMat=null;}

function rDL(){const s=norm(document.getElementById('srcD')?.value||''),list=document.getElementById('dSelList');if(!list)return;let items=Object.values(inv).filter(m=>m.cantidad>0);if(s)items=items.filter(m=>norm(m.nombre+' '+m.marca+' '+m.espesor).includes(s));if(!items.length){list.innerHTML=`<div class="es" style="padding:28px"><p>Sin materiales</p></div>`;return;}list.innerHTML=items.map(m=>{const isT=m.tipo==='tablero',u=isT?' lám':' mts',sp=isT?`${m.espesor}mm | ${m.ancho}×${m.largo}mm`:`${m.espesor}mm${m.altoTC?' | Alto:'+m.altoTC+'mm':''}`;return `<div class="msi" onclick="openMD('${m.id}')"><div class="msn">${m.nombre}${m.marca?' — '+m.marca:''}</div><div class="mss">${sp}</div><div class="msk">Stock: ${isT?m.cantidad:Number(m.cantidad).toFixed(1)}${u}</div></div>`;}).join('');}
function openMD(id){selMat=id;const m=inv[id];if(!m)return;const isT=m.tipo==='tablero',u=isT?' lám':' mts',sp=isT?`${m.espesor}mm | ${m.ancho}×${m.largo}mm`:`${m.espesor}mm${m.altoTC?' | Alto:'+m.altoTC+'mm':''}`;document.getElementById('mdInfo').innerHTML=`<div class="mn">${m.nombre}${m.marca?' — '+m.marca:''}</div><div class="ms">${sp}</div><div class="mst ${m.cantidad<(isT?5:50)?'slo':'sok'}" style="margin-top:5px">Stock: ${isT?m.cantidad:Number(m.cantidad).toFixed(1)}${u}</div>`;document.getElementById('mdM2G').style.display=isT?'block':'none';['mdCant','mdM2','mdProy','mdArea','mdPart'].forEach(i=>document.getElementById(i).value='');oM('mDesp');}
async function confMD(){if(!selMat)return;const m=inv[selMat];if(!m)return;const isT=m.tipo==='tablero',cant=isT?parseInt(document.getElementById('mdCant').value):parseFloat(document.getElementById('mdCant').value),m2=parseFloat(document.getElementById('mdM2').value)||0,proy=document.getElementById('mdProy').value.trim(),area=document.getElementById('mdArea').value.trim(),partida=document.getElementById('mdPart').value.trim();if(!cant||cant<=0){toast("Falta cantidad");return;}if(cant>m.cantidad){toast("Stock insuficiente");return;}if(!proy){toast("Falta proyecto");return;}if(!area){toast("Falta área");return;}await doDsp(selMat,cant,m2,proy,area,partida);cM('mDesp');}

async function doDsp(matId,cant,m2,proy,area,partida){const m=inv[matId];if(!m)return;const isT=m.tipo==='tablero';inv[matId].cantidad-=cant;await saveMat(inv[matId]);const u=isT?' lám':' mts',sp=isT?`${m.espesor}mm | ${m.ancho}×${m.largo}mm`:`${m.espesor}mm${m.altoTC?' | Alto:'+m.altoTC+'mm':''}`;await saveD({id:'d_'+Date.now()+'_'+Math.random().toString(36).substr(2,5),matId,matName:m.nombre+(m.marca?' — '+m.marca:''),matSpecs:sp,tipo:m.tipo,cant,unit:u,m2,proy,area,partida:partida||'',user,ts:Date.now()});const rem=inv[matId].cantidad,thr=isT?5:50;let msg=`Despachado: ${cant}${u}`;if(rem<thr&&rem>0)msg+=` ⚠ Quedan ${isT?rem:rem.toFixed(1)}`;toast(msg);rAll();}

// ============================================================
// PARTIDAS
// ============================================================
async function addPart(){const code=document.getElementById('ptCod').value.trim(),name=document.getElementById('ptNom').value.trim();if(!code||!name){toast("Falta código o descripción");return;}if(parts.find(p=>norm(p.code)===norm(code))){toast("Código ya existe");return;}const p={id:'pt_'+Date.now(),code,name};parts.push(p);await savePart(p);document.getElementById('ptCod').value='';document.getElementById('ptNom').value='';toast("Partida agregada");rParts();}
function rParts(){const list=document.getElementById('partList');if(!list)return;if(!parts.length){list.innerHTML=`<div class="es"><p>Sin partidas registradas</p></div>`;return;}list.innerHTML=parts.map(p=>`<div class="part-item"><span class="pi-code">${p.code}</span><span class="pi-name">${p.name}</span><div class="pi-acts"><button class="ba edt bxs" onclick="editPart('${p.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.5 2.5a2.12 2.12 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button><button class="ba del bxs" onclick="askDelPart('${p.id}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></button></div></div>`).join('');}
function editPart(id){const p=parts.find(x=>x.id===id);if(!p)return;const newName=prompt('Nueva descripción para '+p.code+':',p.name);if(newName&&newName.trim()){p.name=newName.trim();savePart(p);rParts();}}
function askDelPart(id){const p=parts.find(x=>x.id===id);if(!p)return;document.getElementById('confTitle').textContent='¿Eliminar partida?';document.getElementById('confText').textContent=p.code+' — '+p.name;document.getElementById('confBtn').onclick=async()=>{await delPartDB(id);cM('mConf');toast("Partida eliminada");rParts();};oM('mConf');}

// ============================================================
// PROYECTOS — individual dispatches with edit, partidas shown
// ============================================================
function rProj(){const cont=document.getElementById('projList');if(!cont)return;if(!desp.length){cont.innerHTML=`<div class="es"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg><p>Sin despachos</p></div>`;return;}
const proj={};desp.forEach(d=>{const p=d.proy||'Sin proyecto',a=d.area||'Sin área';if(!proj[p])proj[p]={areas:{},total:0};if(!proj[p].areas[a])proj[p].areas[a]=[];proj[p].areas[a].push(d);proj[p].total+=d.cant;});
let h='';Object.keys(proj).sort().forEach(pn=>{const pr=proj[pn],aN=Object.keys(pr.areas).sort();h+=`<div class="pc"><div class="ph" onclick="this.classList.toggle('opn');this.nextElementSibling.classList.toggle('opn')"><h4><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>${pn}</h4><div style="display:flex;align-items:center;gap:8px"><span class="ps">${aN.length} área${aN.length>1?'s':''}</span><svg class="chv" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div></div><div class="pb">`;
aN.forEach(an=>{const items=pr.areas[an];h+=`<div class="asec"><div class="atit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>${an}</div>`;
items.forEach(d=>{const q=d.tipo==='tablero'?d.cant:Number(d.cant).toFixed(1);const partTag=d.partida?`<span class="aip">📋 ${d.partida}</span>`:`<span class="aip" style="color:var(--g300);font-style:italic">Sin partida</span>`;h+=`<div class="ai"><span class="ain">${d.matName} <span style="font-size:10px;color:var(--bkm)">${d.matSpecs}</span></span>${partTag}<span class="aiq">${q}${d.unit}</span>${d.m2?`<span class="aim">${d.m2.toFixed(1)}m²</span>`:''}<button class="aie" onclick="openEditDesp('${d.id}')">✏️</button></div>`;});
h+=`</div>`;});
h+=`<div class="p-actions"><button class="ba edt" onclick="editProj('${esc(pn)}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.5 2.5a2.12 2.12 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Renombrar</button><button class="ba del" onclick="delProj('${esc(pn)}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6"/></svg>Eliminar</button></div></div></div>`;});
cont.innerHTML=h;}

// EDIT INDIVIDUAL DESPACHO
let editDespId=null;
function openEditDesp(id){const d=desp.find(x=>x.id===id);if(!d)return;editDespId=id;
document.getElementById('edDespInfo').innerHTML=`<div class="mn">${d.matName}</div><div class="ms">${d.matSpecs}</div>`;
document.getElementById('edDCant').value=d.cant;document.getElementById('edDM2').value=d.m2||'';document.getElementById('edDM2G').style.display=d.tipo==='tablero'?'block':'none';
document.getElementById('edDProy').value=d.proy;document.getElementById('edDArea').value=d.area;document.getElementById('edDPart').value=d.partida||'';
oM('mEditDesp');}

async function saveDespEdit(){if(!editDespId)return;const d=desp.find(x=>x.id===editDespId);if(!d)return;
const newCant=parseFloat(document.getElementById('edDCant').value)||0;const newM2=parseFloat(document.getElementById('edDM2').value)||0;
const newProy=document.getElementById('edDProy').value.trim();const newArea=document.getElementById('edDArea').value.trim();const newPart=document.getElementById('edDPart').value.trim();
if(!newCant||newCant<=0){toast("Falta cantidad");return;}if(!newProy){toast("Falta proyecto");return;}if(!newArea){toast("Falta área");return;}
// If quantity changed, adjust inventory
const diff=newCant-d.cant;if(diff!==0&&d.matId&&inv[d.matId]){inv[d.matId].cantidad-=diff;await saveMat(inv[d.matId]);}
d.cant=newCant;d.m2=newM2;d.proy=newProy;d.area=newArea;d.partida=newPart;
if(useSB)await sb.from('despachos').update({cantidad:d.cant,m2:d.m2,proyecto:d.proy,area:d.area,partida:d.partida}).eq('id',d.id);
else sLoc();
cM('mEditDesp');editDespId=null;toast("Despacho actualizado");rAll();}

async function delDesp(){if(!editDespId)return;const d=desp.find(x=>x.id===editDespId);if(!d)return;
cM('mEditDesp');
document.getElementById('confTitle').textContent='¿Eliminar despacho?';
document.getElementById('confText').textContent=d.matName+' — '+d.cant+d.unit+' → '+d.proy;
document.getElementById('confBtn').onclick=async()=>{
// Return stock to inventory
if(d.matId&&inv[d.matId]){inv[d.matId].cantidad+=d.cant;await saveMat(inv[d.matId]);}
if(useSB)await sb.from('despachos').delete().eq('id',d.id);
desp=desp.filter(x=>x.id!==d.id);if(!useSB)sLoc();
cM('mConf');editDespId=null;toast("Despacho eliminado");rAll();};
oM('mConf');}
function editProj(name){document.getElementById('epOld').value=name;document.getElementById('epNew').value=name;oM('mEditProj');}
async function saveProj(){const oldN=document.getElementById('epOld').value,newN=document.getElementById('epNew').value.trim();if(!newN){toast("Falta nombre");return;}await updateDespProy(oldN,newN);cM('mEditProj');toast("Proyecto renombrado");rProj();rRes();}
function delProj(name){document.getElementById('confTitle').textContent='¿Eliminar proyecto?';document.getElementById('confText').textContent='Se borrarán todos los despachos de: '+name;document.getElementById('confBtn').onclick=async()=>{await deleteDespByProy(name);cM('mConf');toast("Proyecto eliminado");rAll();};oM('mConf');}

// ============================================================
// RESUMEN — grouped by project+area with totals
// ============================================================
function sToday(){document.getElementById('resDate').value=todS();rRes();}
function rRes(){const ds=document.getElementById('resDate')?.value;if(!ds)return;const cont=document.getElementById('resCont');if(!cont)return;const s=new Date(ds+'T00:00:00').getTime(),e=s+864e5,dd=desp.filter(d=>d.ts>=s&&d.ts<e);if(!dd.length){cont.innerHTML=`<div class="es"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg><p>Sin despachos</p></div>`;return;}
// Group by project > area > aggregate materials
const grp={};dd.forEach(d=>{const p=d.proy||'Sin proyecto',a=d.area||'Sin área';const k=p+'|||'+a;if(!grp[k])grp[k]={proy:p,area:a,items:{}};const mk=d.matName;if(!grp[k].items[mk])grp[k].items[mk]={cant:0,m2:0,tipo:d.tipo,unit:d.unit,specs:d.matSpecs,partida:''};grp[k].items[mk].cant+=d.cant;if(d.m2)grp[k].items[mk].m2+=d.m2;if(d.partida)grp[k].items[mk].partida=d.partida;});
let h=`<div class="stot"><div class="bn">${dd.length}</div><div class="lb">Despachos del día</div></div>`;
const groups=Object.values(grp).sort((a,b)=>a.proy.localeCompare(b.proy)||a.area.localeCompare(b.area));
let lastProy='';
groups.forEach(g=>{if(g.proy!==lastProy){h+=`<div class="sg-proj"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>${g.proy}</div>`;lastProy=g.proy;}
h+=`<div class="sg-area">📍 ${g.area}</div>`;
for(const[name,data]of Object.entries(g.items)){const q=data.tipo==='tablero'?data.cant:Number(data.cant).toFixed(1);h+=`<div class="di"><div class="dinf"><div class="mn">${name}</div><div class="dm">${data.specs}${data.partida?' | 📋 '+data.partida:''}${data.m2?' | '+data.m2.toFixed(1)+'m²':''}</div></div><div class="dq">-${q}${data.unit}</div></div>`;}});
cont.innerHTML=h;}
function expRes(){const ds=document.getElementById('resDate')?.value;if(!ds)return;const s=new Date(ds+'T00:00:00').getTime(),e=s+864e5,dd=desp.filter(d=>d.ts>=s&&d.ts<e);if(!dd.length){toast("Sin despachos");return;}
// Group same way as render
const grp={};dd.forEach(d=>{const p=d.proy||'?',a=d.area||'?',k=p+'|||'+a;if(!grp[k])grp[k]={proy:p,area:a,items:{}};const mk=d.matName;if(!grp[k].items[mk])grp[k].items[mk]={cant:0,m2:0,tipo:d.tipo,unit:d.unit,partida:''};grp[k].items[mk].cant+=d.cant;if(d.m2)grp[k].items[mk].m2+=d.m2;if(d.partida)grp[k].items[mk].partida=d.partida;});
const dD=new Date(ds).toLocaleDateString('es',{day:'numeric',month:'long',year:'numeric'});
let t=`📋 *ALMACÉN DE CARPINTERÍA*\n📅 ${dD}\n${'─'.repeat(28)}\n\n`;
let lastP='';Object.values(grp).sort((a,b)=>a.proy.localeCompare(b.proy)).forEach(g=>{if(g.proy!==lastP){t+=`🏗 *${g.proy}*\n`;lastP=g.proy;}t+=`  📍 ${g.area}\n`;for(const[name,data]of Object.entries(g.items)){const q=data.tipo==='tablero'?data.cant:Number(data.cant).toFixed(1);t+=`    • ${name}: ${q}${data.unit}${data.m2?' ('+data.m2.toFixed(1)+'m²)':''}${data.partida?' ['+data.partida+']':''}\n`;}t+='\n';});
t+=`${'─'.repeat(28)}\n*Total: ${dd.length} despachos*`;
if(navigator.clipboard)navigator.clipboard.writeText(t).then(()=>toast("Copiado")).catch(()=>fbC(t));else fbC(t);}
function fbC(t){const a=document.createElement('textarea');a.value=t;a.style.cssText='position:fixed;opacity:0';document.body.appendChild(a);a.focus();a.select();try{document.execCommand('copy');toast("Copiado");}catch(e){}document.body.removeChild(a);}

function toast(m){const t=document.getElementById('T');t.textContent=m;t.classList.add('sh');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('sh'),2800);}
document.getElementById('resDate').value=todS();
document.addEventListener('focusin',e=>{if(e.target.matches('input,select,textarea'))setTimeout(()=>e.target.scrollIntoView({behavior:'smooth',block:'center'}),300);});
</script>
