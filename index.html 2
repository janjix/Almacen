function togV(c){const r=getRec(c);if(!r){toast("Sin soporte de voz");return;}const bid=c==='i'?'vbI':'vbD',sid=c==='i'?'vsI':'vsD';if(recS[c]){r.stop();stopV(c);}else{Object.keys(recS).forEach(k=>{if(recS[k]&&recs[k]){recs[k].stop();stopV(k);}});try{r.start();recS[c]=true;document.getElementById(bid).classList.add('rec');document.getElementById(sid).textContent='Escuchando...';}catch(e){toast("Error micrófono");}}}
